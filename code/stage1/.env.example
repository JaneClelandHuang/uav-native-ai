# Copy to .env and adjust as needed.

# Pinned SITL image. Students: leave as the instructor-provided GHCR tag.
# Instructor/local dev: matches whatever `docker build -t ...` tag you used.
SITL_IMAGE=ghcr.io/janeclelandhuang/uav-course-sitl:copter-4.6.3

# Single-vehicle stage; kept as config, not hardcoded, since Stage 6 adds a
# second simulated vehicle.
VEHICLE_ID=1

# SITL start location: lat,lon,alt(m),heading(deg). Defaults to the Notre
# Dame area (matches the example coordinates in drone-infra-spec.md's
# telemetry schema) instead of ArduPilot's own default (CMAC, Canberra).
SITL_LOCATION=41.700000,-86.239000,225,0
